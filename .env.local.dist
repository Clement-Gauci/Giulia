# =====================================================================
#  Modèle de configuration de PRODUCTION
#
#  Sur le serveur de prod :
#    cp .env.local.dist .env.local
#    # renseigner les valeurs ci-dessous, puis :
#    php bin/console cache:clear
#
#  Le fichier .env.local (avec les vraies valeurs) NE DOIT PAS être
#  commité — il est ignoré par .gitignore. Ce modèle-ci, lui, l'est
#  et ne contient donc aucun secret : que des valeurs à remplacer.
# =====================================================================

# Environnement d'exécution
APP_ENV=prod

# Clé secrète de l'application — générer une valeur unique :
#   php -r 'echo bin2hex(random_bytes(16)), PHP_EOL;'
APP_SECRET=

###> Serveur SMTP — formulaire de contact (envoi synchrone) ###
#   Format : smtp://UTILISATEUR:MOTDEPASSE@HOTE:PORT
#     - port 587 = STARTTLS (recommandé) · 465 = TLS implicite
#     - encoder les caractères spéciaux du login/mot de passe :
#       @ → %40 · : → %3A · / → %2F · espace → %20
#   Exemple : smtp://contact%40giulia-pizza-gorges.fr:m0tDeP@sse@ssl0.ovh.net:587
MAILER_DSN=smtp://UTILISATEUR:MOTDEPASSE@HOTE:587

# Adresses e-mail du formulaire de contact
CONTACT_FROM_EMAIL=no-reply@giulia-pizza-gorges.fr
CONTACT_TO_EMAIL=hello@giulia-pizza-gorges.fr

# Google Analytics 4 — laisser vide/commenté pour désactiver le suivi
#GA_MEASUREMENT_ID=G-XXXXXXXXXX
