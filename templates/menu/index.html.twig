{% extends 'base.html.twig' %}

{% block title %}Toutes nos pizzas — Giulia, pizzeria napolitaine à Gorges{% endblock %}
{% block description %}La carte complète des pizzas napolitaines de Giulia à Gorges : pâte maturée 48h, 33 cm, à emporter en click & collect.{% endblock %}

{% block body %}
    {# Titre #}
    <div class="page-head page-head--roomy">
        <div class="eyebrow"><span class="eyebrow__dot"></span><span class="eyebrow__label">La carte complète</span></div>
        <h1 class="page-title">Toutes nos pizzas</h1>
        <p class="page-lede">Pâte napolitaine maturée 48h, 33 cm de diamètre, pour 1 à 2 personnes. Toutes nos pizzas sont préparées à la commande, à emporter en <strong>click &amp; collect</strong>.</p>
    </div>

    {# Légende #}
    <div class="legend">
        <span class="legend__tag legend__tag--veg"><span class="legend__ico">🌱</span>Végétarienne</span>
        <span class="legend__tag legend__tag--spicy"><span class="legend__ico">🌶️</span>Piquante</span>
        <span class="legend__tag legend__tag--sig"><span class="legend__ico">★</span>Signature</span>
    </div>

    {# Catégories #}
    {% for category in categories %}
        <div class="menu-cat">
            <div class="menu-cat__head">
                <div>
                    <div class="menu-cat__kicker">{{ category.kicker }}</div>
                    <h2 class="menu-cat__label">{{ category.label }}</h2>
                </div>
                <span class="menu-cat__line"></span>
            </div>
            <div class="pizza-grid">
                {% for pizza in category.pizzas %}
                    {% set tone = pizza.isSignature ? 'tone--dark' : ['tone--green', 'tone--blue', 'tone--tan'][loop.index0 % 3] %}
                    <a href="{{ path('menu_show', { slug: pizza.slug }) }}" class="pizza-tile{{ pizza.isSignature ? ' pizza-tile--dark' : '' }}" data-ga-event="pizza_view" data-ga-slug="{{ pizza.slug }}">
                        <div class="pizza-tile__photo {{ tone }}">
                            <span class="ph-label">Photo à venir</span>
                            {% if pizza.isSignature %}<span class="ph-badge">Signature</span>{% endif %}
                        </div>
                        <div class="pizza-tile__body">
                            <div class="pizza-tile__head">
                                <div class="pizza-tile__name">{{ pizza.name }}</div>
                                <div class="pizza-tile__tags">
                                    {% for tag in pizza.tags %}
                                        <span class="tagchip tagchip--{{ tag.value }}" title="{{ tag.label }}">{{ tag.icon }}</span>
                                    {% endfor %}
                                </div>
                            </div>
                            <div class="pizza-tile__desc">{{ pizza.ingredients|join(' · ') }}</div>
                            <div class="pizza-tile__price">{{ pizza.price.format }}</div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        </div>
    {% endfor %}

    {# Note allergies & femmes enceintes #}
    <div class="note u-mt26">
        <svg class="ico--t2" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v5M12 16h.01"></path></svg>
        <p><strong>Allergènes &amp; intolérances :</strong> signalez-les à la commande, on adapte quand c’est possible. <strong>Femmes enceintes :</strong> plusieurs de nos produits (fromages au lait cru, charcuteries et saumon crus) sont ajoutés après cuisson — demandez-nous conseil.</p>
    </div>

    {# CTA Click & Collect #}
    {% set e = establishment() %}
    <a id="commander" href="{{ e.orderUrl }}" class="cta" data-ga-event="click_and_collect" data-ga-location="menu">
        <div class="cta__row">
            <div class="cta__left">
                <div class="cta__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2a3138" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg></div>
                <div>
                    <div class="cta__title">Commander en Click &amp; Collect</div>
                    <div class="cta__sub">Commandez en ligne, retirez sur place</div>
                </div>
            </div>
            <svg class="ico" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#d3a273" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
        </div>
    </a>
    <p class="cta-note">Plus de <strong>5 pizzas</strong> ? Appelez-nous au <a href="tel:{{ e.phoneHref }}" data-ga-event="phone">{{ e.phone }}</a>, on trouve toujours une solution.</p>

    {{ include('components/_hours.html.twig') }}
{% endblock %}
