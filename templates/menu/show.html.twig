{% extends 'base.html.twig' %}

{% block title %}{{ pizza.name }} — Pizza napolitaine · Giulia, Gorges{% endblock %}
{% block description %}{{ pizza.name }} : {{ pizza.ingredients|join(', ') }}. Pizza napolitaine à emporter en click & collect chez Giulia, Gorges.{% endblock %}

{% block body %}
    {# Fil d'Ariane #}
    <div style="display:flex;align-items:center;gap:8px;margin:18px 2px 0;font-size:12.5px;color:#8a8377;">
        <a href="{{ path('menu_index') }}" style="color:#8a8377;font-weight:600;">Toutes nos pizzas</a>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#c3b7a2" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg>
        <span style="color:#5f584d;font-weight:600;">{{ pizza.name }}</span>
    </div>

    {# Carte héro #}
    <div style="position:relative;margin-top:14px;background:#2a3138;border-radius:24px;overflow:hidden;box-shadow:0 22px 50px -26px rgba(42,49,56,.65);color:#f4ede0;">
        <div style="position:absolute;inset:0;background-image:radial-gradient(circle at 88% 8%, rgba(211,162,115,.28), transparent 46%), radial-gradient(circle at 4% 96%, rgba(154,171,147,.22), transparent 44%);"></div>
        <div style="position:relative;height:210px;background:#343b42;background-image:repeating-linear-gradient(135deg, rgba(211,162,115,.20) 0 12px, transparent 12px 24px);display:flex;align-items:center;justify-content:center;">
            <span style="font-family:monospace;font-size:11px;letter-spacing:1px;color:#8a7f70;text-transform:uppercase;">Photo de la pizza</span>
            {% if pizza.isFeatured %}<span style="position:absolute;top:12px;left:12px;background:#d3a273;color:#2a3138;font-size:9.5px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:5px 11px;border-radius:100px;">Pizza du moment</span>{% endif %}
        </div>
        <div style="position:relative;padding:22px 24px 26px;">
            <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:12px;">
                <h1 style="margin:0;font-family:var(--font-title);font-weight:800;font-size:44px;line-height:.95;letter-spacing:-1px;">{{ pizza.name }}</h1>
                <span style="font-family:var(--font-title);font-weight:700;font-size:24px;color:#a9c39a;white-space:nowrap;">{{ pizza.price.format }}</span>
            </div>
            <p style="margin:14px 0 0;font-size:15px;line-height:1.6;color:#d8d0c2;">
                {%- if pizza.isFeatured -%}Notre signature du moment : une base napolitaine relevée d’ingrédients de caractère, préparée à la commande.
                {%- else -%}Pizza napolitaine préparée à la commande, sur notre pâte maturée 48h.{%- endif -%}
            </p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:2px 22px;margin-top:18px;">
                {% for ing in pizza.ingredients %}
                    <div style="display:flex;align-items:center;gap:9px;padding:7px 0;border-top:1px solid rgba(244,237,224,.1);font-size:14px;color:#e4dccc;"><span style="color:#d3a273;font-size:10px;">◆</span>{{ ing }}</div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Chips méta #}
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-top:14px;">
        <div style="background:#fffdf8;border:1px solid #e7ddca;border-radius:15px;padding:14px 12px;text-align:center;"><div style="font-family:var(--font-title);font-weight:800;font-size:19px;color:#3a4148;">33 cm</div><div style="font-size:11.5px;color:#8a8377;margin-top:2px;">Diamètre</div></div>
        <div style="background:#fffdf8;border:1px solid #e7ddca;border-radius:15px;padding:14px 12px;text-align:center;"><div style="font-family:var(--font-title);font-weight:800;font-size:19px;color:#3a4148;">48 h</div><div style="font-size:11.5px;color:#8a8377;margin-top:2px;">Maturation pâte</div></div>
        <div style="background:#fffdf8;border:1px solid #e7ddca;border-radius:15px;padding:14px 12px;text-align:center;"><div style="font-family:var(--font-title);font-weight:800;font-size:19px;color:#3a4148;">1–2</div><div style="font-size:11.5px;color:#8a8377;margin-top:2px;">Personnes</div></div>
    </div>

    {# Allergènes #}
    <div style="margin-top:14px;background:#f6ece1;border:1px solid #ecd9c1;border-radius:16px;padding:14px 16px;display:flex;gap:11px;align-items:flex-start;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-top:2px;flex-shrink:0;"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v5M12 16h.01"></path></svg>
        <p style="margin:0;font-size:13.5px;line-height:1.6;color:#7a5a3c;">{% if pizza.allergens is not empty %}<strong style="color:#5f4326;">Allergènes :</strong> {{ pizza.allergens|join(', ') }}. {% endif %}Une intolérance ? Signalez-le à la commande, on adapte quand c’est possible.</p>
    </div>

    {# CTA #}
    {% set e = establishment() %}
    <a href="{{ e.menuPdfUrl }}" style="display:block;margin-top:16px;background:#2a3138;color:#f4ede0;border-radius:20px;padding:20px 22px;box-shadow:0 16px 36px -18px rgba(42,49,56,.6);">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:14px;">
            <div style="display:flex;align-items:center;gap:14px;">
                <div style="width:46px;height:46px;border-radius:14px;background:#d3a273;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2a3138" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                </div>
                <div>
                    <div style="font-family:var(--font-title);font-weight:800;font-size:19px;">Ajouter en Click &amp; Collect</div>
                    <div style="font-size:13.5px;color:#b9b1a4;margin-top:1px;">Commandez en ligne, retirez sur place</div>
                </div>
            </div>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#d3a273" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
        </div>
    </a>

    <a href="{{ path('menu_index') }}" style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:10px;padding:14px;border-radius:15px;border:1.5px dashed #cdbfa4;background:transparent;font-family:var(--font-title);font-weight:700;font-size:15px;color:#5f584d;">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M11 6l-6 6 6 6"></path></svg>
        Retour à toutes nos pizzas
    </a>

    {{ include('components/_hours.html.twig') }}
{% endblock %}
