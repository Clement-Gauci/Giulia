{% extends 'base.html.twig' %}

{% block title %}{{ pizza.name }} — Pizza napolitaine · Giulia, Gorges{% endblock %}
{% block description %}{{ pizza.name }} : {{ pizza.ingredients|join(', ') }}. Pizza napolitaine à emporter en click & collect chez Giulia, Gorges.{% endblock %}

{% block body %}
    {# Fil d'Ariane #}
    <div class="crumbs">
        <a href="{{ path('menu_index') }}">Toutes nos pizzas</a>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#c3b7a2" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg>
        <span class="crumbs__here">{{ pizza.name }}</span>
    </div>

    {# Carte héro #}
    <div class="pizza-hero">
        <div class="featured__glow"></div>
        <div class="pizza-hero__photo">
            <span class="pizza-hero__ph-label">Photo de la pizza</span>
            {% if pizza.isFeatured %}<span class="ph-badge ph-badge--lg">Pizza du moment</span>{% endif %}
        </div>
        <div class="featured__body">
            <div class="featured__head">
                <h1 class="featured__name">{{ pizza.name }}</h1>
                <span class="featured__price">{{ pizza.price.format }}</span>
            </div>
            <p class="pizza-hero__tagline">
                {%- if pizza.isFeatured -%}Notre signature du moment : une base napolitaine relevée d’ingrédients de caractère, préparée à la commande.
                {%- else -%}Pizza napolitaine préparée à la commande, sur notre pâte maturée 48h.{%- endif -%}
            </p>
            <div class="ing-grid">
                {% for ing in pizza.ingredients %}
                    <div class="ing"><span class="ing__b">◆</span>{{ ing }}</div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Chips méta #}
    <div class="meta-chips">
        <div class="meta-chip"><div class="meta-chip__v">33 cm</div><div class="meta-chip__l">Diamètre</div></div>
        <div class="meta-chip"><div class="meta-chip__v">48 h</div><div class="meta-chip__l">Maturation pâte</div></div>
        <div class="meta-chip"><div class="meta-chip__v">1–2</div><div class="meta-chip__l">Personnes</div></div>
    </div>

    {# Allergènes #}
    <div class="note u-mt14">
        <svg class="ico--t2" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v5M12 16h.01"></path></svg>
        <p>{% if pizza.allergens is not empty %}<strong>Allergènes :</strong> {{ pizza.allergens|join(', ') }}. {% endif %}Une intolérance ? Signalez-le à la commande, on adapte quand c’est possible.</p>
    </div>

    {# CTA #}
    {% set e = establishment() %}
    <a href="{{ e.menuPdfUrl }}" class="cta">
        <div class="cta__row">
            <div class="cta__left">
                <div class="cta__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2a3138" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg></div>
                <div>
                    <div class="cta__title">Ajouter en Click &amp; Collect</div>
                    <div class="cta__sub">Commandez en ligne, retirez sur place</div>
                </div>
            </div>
            <svg class="ico" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#d3a273" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
        </div>
    </a>

    <a href="{{ path('menu_index') }}" class="back-cta back-cta--tight">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M11 6l-6 6 6 6"></path></svg>
        Retour à toutes nos pizzas
    </a>

    {{ include('components/_hours.html.twig') }}
{% endblock %}
