{% extends 'base.html.twig' %}

{% block title %}Contact — Giulia, pizzeria napolitaine à Gorges (Clisson, Nantes){% endblock %}
{% block description %}Contactez la pizzeria Giulia à Gorges : question sur une commande, événement, allergie. Écrivez-nous ou appelez directement.{% endblock %}

{% block body %}
    {% set e = establishment() %}

    {# Fil d'Ariane #}
    <div class="crumbs">
        <a href="{{ path('home') }}">Accueil</a>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#c3b7a2" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg>
        <span class="crumbs__here">Contact</span>
    </div>

    {# Titre #}
    <div class="page-head">
        <div class="eyebrow"><span class="eyebrow__dot"></span><span class="eyebrow__label">On vous répond vite</span></div>
        <h1 class="page-title">Contactez-nous</h1>
        <p class="page-lede">Une question sur une commande, un événement à organiser, une allergie à signaler ? Écrivez-nous ou appelez la pizzeria directement — <strong>on trouve toujours une solution.</strong></p>
    </div>

    {# Chips contact rapide #}
    <div class="chips">
        <a href="tel:{{ e.phoneHref }}" class="chip chip--dark">
            <span class="chip__icon ic-terra"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2a3138" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path></svg></span>
            <span class="chip__body"><span class="chip__k">Appeler</span><span class="chip__v">{{ e.phone }}</span></span>
        </a>
        <a href="mailto:{{ e.email }}" class="chip chip--light">
            <span class="chip__icon ic-green"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5c8a49" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 6L2 7"></path></svg></span>
            <span class="chip__body"><span class="chip__k">Écrire</span><span class="chip__v">{{ e.email }}</span></span>
        </a>
    </div>

    {# Formulaire #}
    <section class="panel panel--form">
        {% for message in app.flashes('success') %}
            <div class="form-success">
                <svg class="ico" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5c8a49" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg>
                {{ message }}
            </div>
        {% endfor %}

        <div class="panel__head panel__head--mb16">
            <span class="panel__icon ic-warm"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg></span>
            <h2 class="panel__title">Écrivez-nous un mot</h2>
        </div>

        {{ form_start(form) }}
            <div class="field-row">
                <label class="field">
                    <span class="field__label">Votre nom</span>
                    {{ form_widget(form.name, { attr: { class: 'field__input', placeholder: 'Prénom Nom' } }) }}
                    {{ form_errors(form.name) }}
                </label>
                <label class="field">
                    <span class="field__label">Téléphone <span class="field__opt">(facultatif)</span></span>
                    {{ form_widget(form.phone, { attr: { class: 'field__input', placeholder: '06 12 34 56 78' } }) }}
                    {{ form_errors(form.phone) }}
                </label>
            </div>
            <label class="field field--mt">
                <span class="field__label">Votre email</span>
                {{ form_widget(form.email, { attr: { class: 'field__input', placeholder: 'vous@email.fr' } }) }}
                {{ form_errors(form.email) }}
            </label>
            <label class="field field--mt">
                <span class="field__label">Sujet</span>
                {{ form_widget(form.subject, { attr: { class: 'field__input' } }) }}
                {{ form_errors(form.subject) }}
            </label>
            <label class="field field--mt" data-controller="char-counter" data-char-counter-max-value="600">
                <span class="field__label field__label--row"><span>Votre message</span><span class="field__count" data-char-counter-target="out">0/600</span></span>
                {{ form_widget(form.message, { attr: { class: 'field__input', rows: 4, maxlength: 600, placeholder: 'Dites-nous tout…', 'data-char-counter-target': 'input', 'data-action': 'input->char-counter#update' } }) }}
                {{ form_errors(form.message) }}
            </label>

            <button type="submit" class="btn-send">
                Envoyer le message
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d3a273" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path></svg>
            </button>
            <p class="form-hint">Votre message nous est envoyé par e-mail. Nous vous répondons en général sous 24 h.</p>
        {{ form_end(form) }}
    </section>

    {# Nous trouver #}
    <section class="panel">
        <div class="panel__head">
            <span class="panel__icon ic-blue"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#5786a0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg></span>
            <h2 class="panel__title">Nous trouver</h2>
        </div>
        <a href="{{ e.directionsUrl }}" target="_blank" rel="noopener" class="map">
            <span class="map__pin"><svg width="30" height="30" viewBox="0 0 24 24" fill="#b3743f" stroke="#fffdf8" stroke-width="1.4" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3" fill="#fffdf8" stroke="none"></circle></svg></span>
            <span class="map__open">Ouvrir dans Maps <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"></path></svg></span>
        </a>
        <div class="access">
            <div class="access__row"><svg class="ico--t2" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#a59b88" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg><span>{{ e.address }}<br><span class="access__sub">À 5 min de Clisson · 25 min de Nantes</span></span></div>
            <div class="access__row"><svg class="ico--t2" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#a59b88" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="16" r="1"></circle><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg><span>Parking gratuit devant la pizzeria</span></div>
        </div>
    </section>

    {{ include('components/_hours.html.twig') }}
{% endblock %}
