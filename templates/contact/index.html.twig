{% extends 'base.html.twig' %}

{% block title %}Contact — Giulia, pizzeria napolitaine à Gorges (Clisson, Nantes){% endblock %}
{% block description %}Contactez la pizzeria Giulia à Gorges : question sur une commande, événement, allergie. Écrivez-nous ou appelez directement.{% endblock %}

{% block body %}
    {% set e = establishment() %}
    {% set input_style = 'padding:11px 13px;border-radius:11px;border:1px solid #e2d8c5;background:#fbf6ec;font-size:14.5px;color:#2a3138;width:100%;box-sizing:border-box;' %}

    {# Fil d'Ariane #}
    <div style="display:flex;align-items:center;gap:8px;margin:18px 2px 0;font-size:12.5px;color:#8a8377;">
        <a href="{{ path('home') }}" style="color:#8a8377;font-weight:600;">Accueil</a>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#c3b7a2" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg>
        <span style="color:#5f584d;font-weight:600;">Contact</span>
    </div>

    {# Titre #}
    <div style="margin:14px 0 6px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;"><span style="width:7px;height:7px;border-radius:50%;background:#9aab93;"></span><span style="font-family:var(--font-title);font-weight:700;font-size:11.5px;letter-spacing:2px;text-transform:uppercase;color:#8a9a82;">On vous répond vite</span></div>
        <h1 style="margin:0;font-family:var(--font-title);font-weight:800;font-size:34px;line-height:1;letter-spacing:-1px;">Contactez-nous</h1>
        <p style="margin:9px 0 0;max-width:490px;font-size:14.5px;line-height:1.6;color:#6b6459;">Une question sur une commande, un événement à organiser, une allergie à signaler ? Écrivez-nous ou appelez la pizzeria directement — <strong style="color:#5f584d;">on trouve toujours une solution.</strong></p>
    </div>

    {# Chips contact rapide #}
    <div style="margin-top:20px;display:grid;grid-template-columns:1fr 1fr;gap:9px;">
        <a href="tel:{{ e.phoneHref }}" style="background:#2a3138;color:#f4ede0;border-radius:16px;padding:15px 16px;display:flex;align-items:center;gap:12px;box-shadow:0 14px 30px -20px rgba(42,49,56,.6);">
            <span style="width:40px;height:40px;border-radius:12px;background:#d3a273;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2a3138" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path></svg></span>
            <span style="min-width:0;"><span style="display:block;font-size:11.5px;letter-spacing:.4px;text-transform:uppercase;color:#b9b1a4;">Appeler</span><span style="display:block;font-family:var(--font-title);font-weight:700;font-size:15.5px;">{{ e.phone }}</span></span>
        </a>
        <a href="mailto:{{ e.email }}" style="background:#fffdf8;border:1px solid #e7ddca;border-radius:16px;padding:15px 16px;display:flex;align-items:center;gap:12px;">
            <span style="width:40px;height:40px;border-radius:12px;background:#eef2ea;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5c8a49" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 6L2 7"></path></svg></span>
            <span style="min-width:0;"><span style="display:block;font-size:11.5px;letter-spacing:.4px;text-transform:uppercase;color:#a59b88;">Écrire</span><span style="display:block;font-family:var(--font-title);font-weight:700;font-size:14px;color:#3a4148;overflow:hidden;text-overflow:ellipsis;">{{ e.email }}</span></span>
        </a>
    </div>

    {# Formulaire #}
    <section style="margin-top:12px;background:#fffdf8;border:1px solid #e7ddca;border-radius:20px;padding:22px;">
        {% for message in app.flashes('success') %}
            <div style="display:flex;align-items:center;gap:10px;background:#eaf1e6;border:1px solid #cfe0c6;color:#4a6a3f;border-radius:12px;padding:12px 14px;margin-bottom:16px;font-size:14px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5c8a49" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M20 6L9 17l-5-5"></path></svg>
                {{ message }}
            </div>
        {% endfor %}

        <div style="display:flex;align-items:center;gap:11px;margin-bottom:16px;">
            <span style="width:38px;height:38px;border-radius:11px;background:#f6ece1;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg></span>
            <h2 style="margin:0;font-family:var(--font-title);font-weight:800;font-size:18px;letter-spacing:-.2px;">Écrivez-nous un mot</h2>
        </div>

        {{ form_start(form) }}
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:11px;">
                <label style="display:flex;flex-direction:column;gap:6px;">
                    <span style="font-size:12.5px;font-weight:600;color:#6b6459;">Votre nom</span>
                    {{ form_widget(form.name, { attr: { style: input_style, placeholder: 'Prénom Nom' } }) }}
                    {{ form_errors(form.name) }}
                </label>
                <label style="display:flex;flex-direction:column;gap:6px;">
                    <span style="font-size:12.5px;font-weight:600;color:#6b6459;">Téléphone <span style="color:#b0a894;font-weight:400;">(facultatif)</span></span>
                    {{ form_widget(form.phone, { attr: { style: input_style, placeholder: '06 12 34 56 78' } }) }}
                    {{ form_errors(form.phone) }}
                </label>
            </div>
            <label style="display:flex;flex-direction:column;gap:6px;margin-top:11px;">
                <span style="font-size:12.5px;font-weight:600;color:#6b6459;">Votre email</span>
                {{ form_widget(form.email, { attr: { style: input_style, placeholder: 'vous@email.fr' } }) }}
                {{ form_errors(form.email) }}
            </label>
            <label style="display:flex;flex-direction:column;gap:6px;margin-top:11px;">
                <span style="font-size:12.5px;font-weight:600;color:#6b6459;">Sujet</span>
                {{ form_widget(form.subject, { attr: { style: input_style ~ 'cursor:pointer;' } }) }}
                {{ form_errors(form.subject) }}
            </label>
            <label style="display:flex;flex-direction:column;gap:6px;margin-top:11px;">
                <span style="font-size:12.5px;font-weight:600;color:#6b6459;">Votre message</span>
                {{ form_widget(form.message, { attr: { style: input_style ~ 'line-height:1.55;resize:vertical;min-height:96px;', rows: 4, placeholder: 'Dites-nous tout…' } }) }}
                {{ form_errors(form.message) }}
            </label>

            <button type="submit" style="margin-top:16px;width:100%;padding:15px;border-radius:14px;border:none;background:#2a3138;color:#f4ede0;font-family:var(--font-title);font-weight:700;font-size:15.5px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:9px;">
                Envoyer le message
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d3a273" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path></svg>
            </button>
            <p style="margin:11px 0 0;font-size:12px;line-height:1.55;color:#a59b88;text-align:center;">Votre message nous est envoyé par e-mail. Nous vous répondons en général sous 24 h.</p>
        {{ form_end(form) }}
    </section>

    {# Nous trouver #}
    <section style="margin-top:12px;background:#fffdf8;border:1px solid #e7ddca;border-radius:20px;padding:20px 22px;">
        <div style="display:flex;align-items:center;gap:11px;margin-bottom:14px;">
            <span style="width:38px;height:38px;border-radius:11px;background:#eaf1f4;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#5786a0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg></span>
            <h2 style="margin:0;font-family:var(--font-title);font-weight:800;font-size:18px;letter-spacing:-.2px;">Nous trouver</h2>
        </div>
        <a href="{{ e.directionsUrl }}" target="_blank" rel="noopener" style="display:block;position:relative;height:150px;border-radius:14px;overflow:hidden;border:1px solid #e2d8c5;background:#e9f0f2;background-image:repeating-linear-gradient(135deg, rgba(87,134,160,.14) 0 11px, transparent 11px 22px);">
            <span style="position:absolute;left:50%;top:50%;transform:translate(-50%,-100%);"><svg width="30" height="30" viewBox="0 0 24 24" fill="#b3743f" stroke="#fffdf8" stroke-width="1.4" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3" fill="#fffdf8" stroke="none"></circle></svg></span>
            <span style="position:absolute;left:12px;bottom:12px;background:#fffdf8;border:1px solid #e2d8c5;border-radius:100px;padding:6px 12px;font-size:12px;font-weight:600;color:#5f584d;display:flex;align-items:center;gap:6px;">Ouvrir dans Maps <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"></path></svg></span>
        </a>
        <div style="margin-top:14px;display:flex;flex-direction:column;gap:9px;font-size:14px;color:#5f584d;">
            <div style="display:flex;gap:10px;align-items:flex-start;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#a59b88" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-top:2px;flex-shrink:0;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg><span>{{ e.address }}<br><span style="color:#8a8377;font-size:13px;">À 5 min de Clisson · 25 min de Nantes</span></span></div>
            <div style="display:flex;gap:10px;align-items:flex-start;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#a59b88" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-top:2px;flex-shrink:0;"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="16" r="1"></circle><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg><span>Parking gratuit devant la pizzeria</span></div>
        </div>
    </section>

    {{ include('components/_hours.html.twig') }}
{% endblock %}
