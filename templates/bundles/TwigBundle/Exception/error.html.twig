{% extends 'base.html.twig' %}

{% set code = status_code|default(404) %}
{% set content = {
    404: { title: 'Cette page est partie en livraison', message: "La page que vous cherchez n'existe pas ou a été déplacée. Pas de panique — tout le reste de la pizzeria est à quelques clics." },
    403: { title: 'Accès réservé à la cuisine', message: "Vous n'avez pas l'autorisation d'accéder à cette page. Si vous pensez que c'est une erreur, contactez-nous." },
    500: { title: 'Notre four fait des siennes', message: "Une erreur inattendue s'est produite de notre côté. On s'en occupe — réessayez dans un instant, ou revenez à l'accueil." },
    503: { title: 'On enfourne une mise à jour', message: "Le site est momentanément indisponible pour maintenance. On revient très vite, plus chaud que jamais." }
} %}
{% set err = content[code]|default(content[404]) %}

{% block title %}Erreur {{ code }} — Giulia{% endblock %}

{% block body %}
    {% set e = establishment() %}
    <section class="error-card">
        <div class="error-card__glow"></div>
        <div class="error-card__wm">{{ code }}</div>
        <div class="error-card__body">
            <div class="error-card__emblem"><img src="{{ asset('images/giulia-icon.png') }}" alt="Giulia"></div>
            <div class="error-card__pill"><span class="error-card__pill-dot"></span><span class="error-card__pill-label">Erreur {{ code }}</span></div>
            <h1 class="error-card__title">{{ err.title }}</h1>
            <p class="error-card__msg">{{ err.message }}</p>
            <div class="error-actions">
                <a href="{{ path('home') }}" class="btn-primary"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#2a3138" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-8 9 8"></path><path d="M5 10v10h14V10"></path></svg>Retour à l’accueil</a>
                <a href="{{ path('menu_index') }}" class="btn-ghost">Voir la carte<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d3a273" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>
            </div>
        </div>
    </section>

    <div class="help-strip">
        <span class="help-strip__icon"><svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path></svg></span>
        <div class="help-strip__body">
            <div class="help-strip__title">Une faim pressante ?</div>
            <div class="help-strip__sub">Appelez-nous directement, on prend votre commande.</div>
        </div>
        <a href="tel:{{ e.phoneHref }}" class="help-strip__cta">{{ e.phone }}</a>
    </div>
{% endblock %}
