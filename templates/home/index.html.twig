{% extends 'base.html.twig' %}

{% block title %}Giulia — Pizzeria napolitaine & pizzas à emporter à Gorges (Clisson, Nantes){% endblock %}
{% block description %}Giulia, pizzeria napolitaine à Gorges : vraies pizzas napolitaines à emporter en click & collect, tout près de Clisson et Nantes. Menu, horaires, avis et commande en ligne.{% endblock %}

{% block body %}
    {% set e = establishment() %}
    {% set status = opening_status() %}
    {% set motd = e.announcement %}

    {# Hero #}
    <div class="hero">
        <img src="{{ asset('images/giulia-wordmark.png') }}" alt="Giulia — Pizzeria napolitaine à Gorges (Clisson, Nantes)" class="hero__logo">
        <h1 class="hero__title">Giulia, pizzeria napolitaine &amp; pizzas à emporter à Gorges</h1>
        <p class="hero__lede">Vraies pizzas napolitaines, à emporter en <strong>click &amp; collect</strong> à Gorges, tout près de <strong>Clisson</strong> et <strong>Nantes</strong>.</p>
        <div class="hero__status" data-controller="live-status" data-live-status-url-value="{{ path('status') }}"><span data-live-status-target="detail">{{ status.detail }}</span></div>
    </div>

    {# Annonce du jour (MOTD) #}
    {% if motd.isActive %}
        <div class="motd">
            <span class="motd__icon">📣</span>
            <div>
                <div class="motd__title">{{ motd.title }}</div>
                <div class="motd__text">{{ motd.text }}</div>
            </div>
        </div>
    {% endif %}

    {# Pizza du moment (special.yaml) ; repli sur la signature du menu #}
    {% set spotlight = special ?? featured %}
    {% if spotlight %}
        {% set initials = '' %}{% for w in spotlight.name|split(' ') %}{% set initials = initials ~ (w|first) %}{% endfor %}
        <div class="featured">
            <div class="featured__glow"></div>
            <div class="featured__wm">{{ initials|upper }}</div>
            <div class="featured__body">
                <div class="featured__kicker">
                    <span class="featured__dot"></span>
                    <span class="featured__label">{{ special ? 'Pizza du moment' : 'La signature' }}</span>
                </div>
                <div class="featured__head">
                    <h2 class="featured__name">{{ spotlight.name }}</h2>
                    <span class="featured__price">{{ spotlight.price.format }}</span>
                </div>
                <div class="ing-grid">
                    {% for ingredient in spotlight.ingredients %}
                        <div class="ing"><span class="ing__b">◆</span>{{ ingredient }}</div>
                    {% endfor %}
                </div>
                {% if special %}
                    <a href="{{ e.orderUrl }}" class="featured__cta">Commander en Click &amp; Collect<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d3a273" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>
                {% else %}
                    <a href="{{ path('menu_show', { slug: spotlight.slug }) }}" class="featured__cta">Voir la fiche<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d3a273" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>
                {% endif %}
            </div>
        </div>
    {% endif %}

    {# Slider — nos pizzas #}
    {% set allPizzas = [] %}
    {% for category in categories %}{% set allPizzas = allPizzas|merge(category.pizzas) %}{% endfor %}
    <div class="slider" data-controller="pizza-slider">
        <div class="slider__head">
            <div>
                <div class="eyebrow"><span class="eyebrow__dot"></span><span class="eyebrow__label">La carte</span></div>
                <h2 class="slider__title">Nos pizzas napolitaines</h2>
                <p class="slider__sub">33 cm de diamètre · pour 1 à 2 personnes</p>
            </div>
            <div class="slider__nav">
                <button type="button" data-action="pizza-slider#prev" aria-label="Précédent" class="slider__btn"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#5f584d" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"></path></svg></button>
                <button type="button" data-action="pizza-slider#next" aria-label="Suivant" class="slider__btn"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#5f584d" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></button>
            </div>
        </div>
        <div class="slider__track" data-pizza-slider-target="scroller">
            {% for pizza in allPizzas %}
                {% set tone = pizza.isSignature ? 'tone--dark' : ['tone--green', 'tone--blue', 'tone--tan'][loop.index0 % 3] %}
                <a href="{{ path('menu_show', { slug: pizza.slug }) }}" class="pizza-card{{ pizza.isSignature ? ' pizza-card--dark' : '' }}">
                    <div class="pizza-card__photo {{ tone }}">
                        <span class="ph-label">Photo à venir</span>
                        {% if pizza.isSignature %}<span class="ph-badge">Signature</span>{% endif %}
                    </div>
                    <div class="pizza-card__body">
                        <div class="pizza-card__name">{{ pizza.name }}</div>
                        <div class="pizza-card__desc">{{ pizza.ingredients|join(' · ') }}</div>
                        <div class="pizza-card__price">{{ pizza.price.format }}</div>
                    </div>
                </a>
            {% endfor %}
        </div>
        <a href="{{ path('menu_index') }}" class="slider__more">Voir toute la carte des pizzas<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>
    </div>

    {# Click & Collect #}
    <a id="commander" href="{{ e.orderUrl }}" class="cta cta--home">
        <div class="cta__row">
            <div class="cta__left">
                <div class="cta__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2a3138" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg></div>
                <div>
                    <div class="cta__title">Click &amp; Collect</div>
                    <div class="cta__sub">Commandez en ligne, retirez sur place</div>
                </div>
            </div>
            <svg class="ico" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#d3a273" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
        </div>
    </a>
    <p class="cta-note">Un créneau n’apparaît plus disponible, ou vous commandez <strong>plus de 5 pizzas</strong> ? Appelez-nous directement au <a href="tel:{{ e.phoneHref }}">{{ e.phone }}</a>, on trouve toujours une solution.</p>

    {# Liens — Tout Giulia en un clic #}
    <div class="divider"><span class="divider__label">Tout Giulia, en un clic</span><span class="divider__line"></span></div>
    <div class="link-list">
        {{ include('components/_link_card.html.twig', {
            href: menu_pdf_url(), icon_variant: 'green', title: 'Notre menu', subtitle: 'Toute la carte en PDF',
            icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5c8a49" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><path d="M14 2v6h6M9 13h6M9 17h4"></path></svg>'
        }, with_context = false) }}
        {{ include('components/_link_card.html.twig', {
            href: e.directionsUrl, external: true, icon_variant: 'blue', title: 'Itinéraire', subtitle: e.address,
            icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5786a0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>'
        }, with_context = false) }}
        {{ include('components/_link_card.html.twig', {
            href: 'tel:' ~ e.phoneHref, icon_variant: 'warm', title: 'Appeler le restaurant', subtitle: e.phone,
            icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>'
        }, with_context = false) }}
        {{ include('components/_link_card.html.twig', {
            href: e.googleReviewsUrl, external: true, icon_variant: 'warm', title: 'Laisser un avis Google', subtitle: 'Votre avis nous aide beaucoup',
            icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="#d3a273" stroke="#d3a273" stroke-width="1.5" stroke-linejoin="round"><path d="M12 2l2.9 6.26L22 9.27l-5 4.87L18.18 21 12 17.5 5.82 21 7 14.14l-5-4.87 7.1-1.01z"></path></svg>'
        }, with_context = false) }}
        {{ include('components/_link_card.html.twig', {
            href: 'mailto:' ~ e.email, icon_variant: 'green', title: 'Nous écrire', subtitle: e.email,
            icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5c8a49" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 6L2 7"></path></svg>'
        }, with_context = false) }}
        {{ include('components/_link_card.html.twig', {
            href: e.whatsappUrl, external: true, accent: true, icon_variant: 'wa', title: 'Groupe WhatsApp anti-gaspi', subtitle: 'Nos invendus à prix mini, en direct',
            icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="#5c8a49"><path d="M12 2a10 10 0 0 0-8.6 15.06L2 22l5.09-1.33A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.08-1.12l-.29-.17-3.02.79.81-2.94-.19-.3A8 8 0 1 1 12 20z"></path></svg>'
        }, with_context = false) }}
        {% if e.socialLinks is not empty %}
            <div class="social-grid">
                {% for link in e.socialLinks %}
                    <a href="{{ link.url }}" target="_blank" rel="noopener" class="social">
                        <span class="social__icon ic-{{ link.icon == 'facebook' ? 'blue' : 'warm' }}">
                            {% if link.icon == 'facebook' %}<svg width="19" height="19" viewBox="0 0 24 24" fill="#5786a0"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"></path></svg>
                            {%- elseif link.icon == 'instagram' -%}<svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="1.2" fill="#b3743f" stroke="none"></circle></svg>
                            {%- else -%}<span class="social__initial">{{ link.label|first }}</span>{% endif %}
                        </span>
                        <span class="social__label">{{ link.label }}</span>
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {{ include('components/_hours.html.twig') }}
{% endblock %}
