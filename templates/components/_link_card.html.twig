{# props : href, icon (svg brut), icon_variant (green|blue|warm|wa), title, subtitle, external?, accent? #}
<a href="{{ href }}"{% if external|default(false) %} target="_blank" rel="noopener"{% endif %} class="link-card{{ accent|default(false) ? ' link-card--accent' : '' }}">
    <span class="link-card__icon ic-{{ icon_variant|default('green') }}">{{ icon|raw }}</span>
    <span class="link-card__text">
        <span class="link-card__title">{{ title }}</span>
        <span class="link-card__sub">{{ subtitle }}</span>
    </span>
    <svg class="ico" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c3b7a2" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg>
</a>
