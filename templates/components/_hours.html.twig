{% set e = establishment() %}
<div id="contact" style="scroll-margin-top:16px;margin-top:26px;background:#fffdf8;border:1px solid #e7ddca;border-radius:20px;padding:20px 22px;">
    <h2 style="margin:0 0 14px;font-family:var(--font-title);font-weight:800;font-size:16px;letter-spacing:.3px;">Horaires d’ouverture · {{ e.name }} · Gorges</h2>
    {% for row in weekly_hours() %}
        <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;padding:7px 0;border-top:1px solid #f0e8d9;font-size:14.5px;">
            <span style="font-weight:600;color:#4a4339;min-width:96px;">{{ row.day }}{{ row.today ? ' (aujourd’hui)' : '' }}</span>
            <span style="text-align:right;color:#6b6459;">{{ row.hours }}</span>
        </div>
    {% endfor %}
    <div style="margin-top:14px;background:#f6ece1;border:1px solid #ecd9c1;border-radius:13px;padding:12px 14px;display:flex;gap:10px;align-items:flex-start;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#b3743f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-top:1px;flex-shrink:0;"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v5M12 16h.01"></path></svg>
        <p style="margin:0;font-size:13px;line-height:1.55;color:#7a5a3c;">Nous proposons les <strong style="color:#5f4326;">grandes pizzas à la demande</strong>, de 11h30 à 14h00 et de 18h00 jusqu’à la fermeture.</p>
    </div>
    <div style="border-top:1px solid #f0e8d9;margin-top:14px;padding-top:16px;display:flex;flex-direction:column;gap:8px;font-size:14px;color:#5f584d;">
        <div style="display:flex;gap:9px;align-items:flex-start;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#a59b88" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-top:2px;flex-shrink:0;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg><span>{{ e.address }}</span></div>
        <div style="display:flex;gap:9px;align-items:center;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#a59b88" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path></svg><a href="tel:{{ e.phoneHref }}" style="color:#5f584d;">{{ e.phone }}</a></div>
        <div style="display:flex;gap:9px;align-items:center;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#a59b88" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 6L2 7"></path></svg><a href="mailto:{{ e.email }}" style="color:#5f584d;">{{ e.email }}</a></div>
    </div>
</div>
